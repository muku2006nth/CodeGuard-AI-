# ML provider: mock | codebert
ML_PROVIDER=mock

# Future CodeBERT checkpoint (after Colab training)
CODEBERT_MODEL_PATH=models/codebert-vuln
ML_SUSPICIOUS_THRESHOLD=0.65

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_CODE_BYTES=512000
REPORTS_DIR=data/reports

# Optional LLM (legacy pipeline — not required for /analyze)
GROQ_API_KEY=
